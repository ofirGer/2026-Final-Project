  <diagram name="ScreenFlow" id="sf">
    <mxGraphModel dx="1422" dy="757" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="תרשים זרימת מסכים (Screen Flow Diagram)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;fontColor=#1F4E79;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="600" height="40" as="geometry" />
        </mxCell>
        <mxCell id="browser" value="🌐 הפעלת המערכת&#xa;&lt;span style='font-size:10px;color:#666'&gt;פתיחת הדפדפן בכתובת&lt;br&gt;http://127.0.0.1:5000&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=12;fontStyle=1;fontColor=#1F4E79;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="lobby" value="🔐 מסך כניסה (Lobby)&#xa;&lt;span style='font-size:10px;color:#444'&gt;נתיב: /lobby&lt;br&gt;שדות: שם משתמש, מפתח נחיל&lt;br&gt;כפתור: Connect to Network&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;fontColor=#1F4E79;" vertex="1" parent="1">
          <mxGeometry x="440" y="100" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="dash" value="📊 לוח הבקרה (Dashboard)&#xa;&lt;span style='font-size:10px;color:#444'&gt;נתיב: /&lt;br&gt;4 כרטיסיות: Downloads, Uploads,&lt;br&gt;My Files, Network Files&lt;br&gt;Polling: /api/data כל 2 שניות&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;fontColor=#1F4E79;" vertex="1" parent="1">
          <mxGeometry x="780" y="100" width="240" height="140" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="פתיחה ראשונה" style="endArrow=block;html=1;strokeColor=#666;fontColor=#666;fontSize=11;fontStyle=1;" edge="1" parent="1" source="browser" target="lobby">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="POST /join&#xa;(username + network_key)" style="endArrow=block;html=1;strokeColor=#82b366;fontColor=#82b366;fontSize=11;fontStyle=1;" edge="1" parent="1" source="lobby" target="dash">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="acTitle" value="פעולות מתוך לוח הבקרה (כל פעולה מבצעת redirect חזרה ל-Dashboard):" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=2;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="200" y="290" width="700" height="30" as="geometry" />
        </mxCell>
        <mxCell id="a1" value="📥  Download&#xa;POST /download&#xa;(file_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="350" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="➕  Add File&#xa;POST /select_file&#xa;(multipart file)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="350" width="160" height="80" as="geometry" />
